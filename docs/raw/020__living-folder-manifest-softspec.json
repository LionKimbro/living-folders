{
  "document": {
    "document-id": "living-folders.manifest.softspec.v0.2",
    "title": "Living Folder Manifest SoftSpec",
    "tags": [
      "living-folders",
      "softspec",
      "json",
      "manifest"
    ],
    "purpose": "Describe the permissive folder-local constitution used by Living Folders.",
    "type": {
      "logical": {
        "base": "file",
        "format": "json",
        "encoding": "utf-8"
      },
      "semantic": {
        "base": "softspec"
      }
    },
    "status": "working"
  },
  "softspec": {
    "types": {
      "folder-button": {
        "type": "object",
        "description": "A compact control-panel affordance.",
        "keys": {
          "id": "stable local identifier",
          "kind": {
            "type": "string",
            "required": true,
            "vocabulary": {
              "navigate": "Navigate Living Folders to target.",
              "command": "Run command from this folder after explicit trust."
            },
            "vocabulary_mode": "closed"
          },
          "label": {
            "type": "string",
            "required": true
          },
          "description": "optional orientation text",
          "target": {
            "type": "filesystem path string",
            "required": "when kind is navigate"
          },
          "command": {
            "type": [
              "string",
              "array"
            ],
            "required": "when kind is command"
          }
        },
        "additional_keys": true
      },
      "map-geometry": {
        "type": "object",
        "description": "Committed rectangle geometry in canvas coordinates.",
        "keys": {
          "x": "integer",
          "y": "integer",
          "width": "integer, at least 70",
          "height": "integer, at least 44"
        },
        "additional_keys": true
      },
      "map-text": {
        "type": "object",
        "description": "A user-authored text annotation placed on the Directory Map.",
        "keys": {
          "id": "stable local identifier",
          "text": "multiline text",
          "x": "integer canvas coordinate",
          "y": "integer canvas coordinate",
          "alignment": {
            "type": "string",
            "vocabulary": {
              "left": "Left-aligned lines.",
              "center": "Centered lines.",
              "right": "Right-aligned lines."
            }
          },
          "font-size": {
            "type": "string",
            "vocabulary": {
              "small": "Small map text.",
              "medium": "Medium map text.",
              "large": "Large map text."
            }
          },
          "color": {
            "type": "string",
            "vocabulary": {
              "white": "White text.",
              "green": "Green text.",
              "blue": "Blue text.",
              "red": "Red text."
            }
          }
        },
        "additional_keys": true
      }
    },
    "schemas": {
      "living-folder-manifest": {
        "title": "Living Folder Manifest",
        "description": "A folder's small local constitution. Unknown keys are preserved.",
        "rules": [
          "Omitting presentation-mode returns presentation authority to inference.",
          "buttons contains user-declared controls; runnable files may additionally be detected from the directory.",
          "directory-map geometry is keyed by the immediate child entry name.",
          "The constitution augments the filesystem and never replaces it."
        ],
        "structure": {
          "type": "object",
          "keys": {
            "living-folder": "format version string",
            "title": "human-facing folder title",
            "role": "semantic role vocabulary; may be inferred or authored",
            "purpose": "short statement of why this place exists",
            "trust-runnable-code": {
              "type": "boolean",
              "description": "Whether the user has explicitly trusted runnable code in this particular folder."
            },
            "presentation-mode": {
              "type": "string",
              "required": false,
              "description": "Explicit presentation override such as directory-map, project-root, workbench, factory, library, gallery, inbox, vault, warehouse, hallway, or ruin."
            },
            "buttons": {
              "type": "array",
              "items": "folder-button"
            },
            "commands": "optional mapped annotations for detected runnable filenames",
            "directory-map": {
              "type": "object",
              "keys": {
                "items": {
                  "type": "object",
                  "key_type": "immediate child filename",
                  "value_type": "map-geometry"
                },
                "texts": {
                  "type": "array",
                  "items": "map-text"
                }
              },
              "additional_keys": true
            }
          },
          "additional_keys": true
        }
      }
    }
  }
}
